# BeatForge AI — Backend environment variables
# Copy to .env and fill in values. Never commit .env to git.

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://your-app.vercel.app

# ── GPU ───────────────────────────────────────────────────────────────────────
# true  = używa CUDA (RTX 2070) dla Whisper + NVENC dla ffmpeg
# false = CPU only
USE_GPU=true

# ── Whisper ───────────────────────────────────────────────────────────────────
# Na RTX 2070 (8 GB VRAM):
#   medium = ~2 GB VRAM, bardzo dobra dokładność  ← polecane
#   large  = ~6 GB VRAM, najlepsza dokładność
WHISPER_MODEL=medium

# ── ffmpeg video encoder ──────────────────────────────────────────────────────
# h264_nvenc = GPU (RTX 2070) — 5-10x szybszy
# libx264    = CPU fallback
VIDEO_ENCODER=h264_nvenc
