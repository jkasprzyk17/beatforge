# BeatForge AI — Backend env vars
# Copy to .env and fill in.  Never commit .env.

# ── Server ────────────────────────────────────────────────
PORT=8000

# ── CORS ──────────────────────────────────────────────────
# Dev: Vite ports  |  Prod: your Vercel URL
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# ── Whisper ───────────────────────────────────────────────
# tiny | base | small | medium | large
# base = fast on CPU, good enough for lyrics
# Options: tiny | base | small | medium | large-v3 | large-v3-turbo | turbo
WHISPER_MODEL=large-v3-turbo
# BCP-47 language code, or "auto" to let Whisper detect automatically
# Examples: pl | en | de | fr | es | auto
WHISPER_LANGUAGE=pl

# ── FFmpeg encoder ────────────────────────────────────────
# macOS dev: libx264  |  Windows RTX: h264_nvenc
VIDEO_ENCODER=libx264
