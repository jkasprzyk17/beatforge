# BeatForge AI — local dev .env
# Copy to backend/.env as well!

PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
WHISPER_MODEL=large-v3-turbo
WHISPER_LANGUAGE=pl
# VIDEO_ENCODER opcje:
#   auto       — wykrywa GPU automatycznie (NVIDIA → AMD → Intel → CPU)
#   h264_nvenc — NVIDIA RTX/GTX (wymagane: CUDA drivers)
#   h264_amf   — AMD RX 5000+ (Windows, wymagane: AMD drivers)
#   h264_qsv   — Intel Quick Sync (iGPU 6th gen+)
#   libx264    — CPU software (wolne, ale zawsze działa)
VIDEO_ENCODER=auto
